# PostgreSQL（含 TimescaleDB 擴充）連線字串
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/trader_risk_radar?schema=public"

# Redis（BullMQ 佇列與快取）
REDIS_URL="redis://localhost:6379"

# Fastify HTTP 埠
PORT=3000

# Hyperliquid API base URLs（公開讀取、免 API key）
HYPERLIQUID_API_BASE_URL="https://api.hyperliquid.xyz"
HYPERLIQUID_STATS_DATA_BASE_URL="https://stats-data.hyperliquid.xyz"

# 背景 worker 設定
MAXIMUM_TRADERS=200
SYNC_INTERVAL_MS=3600000
POLL_INTERVAL_MS=30000
RECOMPUTE_INTERVAL_MS=300000
POLL_LOOKBACK_MS=7776000000
