// Trader Risk Radar — code-first schema (single source of truth for the data model).
// 命名遵循 .sdd/UL-MAP.md：model PascalCase、欄位 camelCase，對應 DB 為 snake_case 全名。
// 金額 / 報酬率一律使用 Decimal，禁用浮點。
//
// 持久化模型：存「原始成交（PositionFill）+ 浮虧快照（PositionSnapshot）」，
// 倉位於讀取時由 domain 的 Position.reconstruct 重建（ingest 無狀態）。

generator client {
  provider = "prisma-client-js"
}

datasource db {
  // Prisma 7：連線 URL 移至 prisma.config.ts（供 Migrate/CLI），
  // 執行時透過 @prisma/adapter-pg driver adapter 連線。
  provider = "postgresql"
}

enum FillSide {
  buy
  sell
}

/// 被追蹤分析的鏈上交易員（錢包地址），來源為 Hyperliquid leaderboard。
model Trader {
  address     String   @id
  firstSeenAt DateTime @default(now()) @map("first_seen_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  metrics TraderMetrics?

  @@map("traders")
}

/// 一筆原始成交（userFillsByTime）。以 tradeId 去重 (idempotency)；倉位由此重建。
model PositionFill {
  tradeId             BigInt   @id @map("trade_id")
  traderAddress       String   @map("trader_address")
  coin                String
  side                FillSide
  price               Decimal  @db.Decimal(38, 18)
  size                Decimal  @db.Decimal(38, 18)
  startPosition       Decimal  @map("start_position") @db.Decimal(38, 18)
  direction           String
  closedProfitAndLoss Decimal  @map("closed_profit_and_loss") @db.Decimal(38, 18)
  occurredAt          DateTime @map("occurred_at")
  hash                String

  @@index([traderAddress, coin, occurredAt])
  @@map("position_fills")
}

/// 每次輪詢對開倉拍下的時間切片，依 trader+coin+time 記錄；讀取時依時間窗掛回對應倉位。
model PositionSnapshot {
  id                                String   @id @default(uuid())
  traderAddress                     String   @map("trader_address")
  coin                              String
  markPrice                         Decimal  @map("mark_price") @db.Decimal(38, 18)
  unrealizedProfitAndLossPercentage Decimal  @map("unrealized_profit_and_loss_percentage") @db.Decimal(18, 8)
  margin                            Decimal  @db.Decimal(38, 18)
  leverage                          Decimal  @db.Decimal(18, 4)
  capturedAt                        DateTime @map("captured_at")

  @@index([traderAddress, coin, capturedAt])
  @@map("position_snapshots")
}

/// 交易員經分析引擎計算後的彙總指標集（見 PRD 第 4 章公式）。
model TraderMetrics {
  traderAddress                   String   @id @map("trader_address")
  maxAdverseExcursionPercentile90 Decimal? @map("max_adverse_excursion_percentile_90") @db.Decimal(18, 8)
  averagingDownRatio              Decimal? @map("averaging_down_ratio") @db.Decimal(9, 8)
  winRate                         Decimal? @map("win_rate") @db.Decimal(9, 8)
  realizedProfitAndLoss           Decimal? @map("realized_profit_and_loss") @db.Decimal(38, 18)
  returnDownsideDeviation         Decimal? @map("return_downside_deviation") @db.Decimal(18, 8)
  averageLeverage                 Decimal? @map("average_leverage") @db.Decimal(18, 4)
  trapSignal                      Decimal? @map("trap_signal") @db.Decimal(9, 8)
  riskScore                       Decimal? @map("risk_score") @db.Decimal(9, 4)
  closedPositionCount             Int      @default(0) @map("closed_position_count")
  insufficientData                Boolean  @default(true) @map("insufficient_data")
  computedAt                      DateTime @updatedAt @map("computed_at")

  trader Trader @relation(fields: [traderAddress], references: [address])

  @@map("trader_metrics")
}
